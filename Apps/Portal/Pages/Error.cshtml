@page
@model ErrorModel
@{
    ViewData["Title"] = "Kesalahan Server";
    Layout = "_LayoutBlank";
}

<div class="text-center py-6">
    <div class="text-[6rem] font-black leading-none mb-4 text-red-500/20">500</div>
    <h1 class="text-2xl font-semibold mb-2">Kesalahan Server</h1>
    <p class="text-muted-foreground text-sm mb-5 max-w-xs mx-auto">
        Terjadi kesalahan saat memproses permintaan Anda. Tim kami telah diberitahu.
    </p>

    @if (Model.ShowRequestId)
    {
        <div class="mb-6">
            <span class="text-xs text-muted-foreground">Request ID: </span>
            <code class="text-xs font-mono bg-muted px-1.5 py-0.5 rounded">@Model.RequestId</code>
        </div>
    }

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn btn-primary"><i class="ti ti-home"></i> Ke Beranda</a>
        <button type="button" data-action="reload" class="btn btn-light"><i class="ti ti-refresh"></i> Coba Lagi</button>
    </div>
</div>
