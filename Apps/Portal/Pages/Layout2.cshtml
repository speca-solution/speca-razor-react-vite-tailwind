@page
@model Speca.Portal.Pages.Layout2Model
@{
    Layout = "Tailwind/_Layout2";
    ViewData["Title"] = "Layout 2 — Horizontal";
    @* Theme bebas dipilih juga di sini, mis.: ViewData["Theme"] = "theme2"; *@
}

@section Breadcrumb {
    <div class="flex flex-wrap items-center justify-between gap-5 pb-7.5">
        <div class="flex flex-col gap-2">
            <h1 class="text-mono text-xl leading-none font-medium">Layout 2 — Horizontal</h1>
            <div class="text-secondary-foreground text-sm">
                Menu di topbar (desktop), drawer saat mobile. Theme tetap theme1 — buktinya theme &amp; layout independen.
            </div>
        </div>
        <a class="btn-outline" href="/">Ke Layout 1</a>
    </div>
}

@await Html.PartialAsync("Tailwind/_DemoWidgets")

<div class="mt-5 mb-10"></div>
