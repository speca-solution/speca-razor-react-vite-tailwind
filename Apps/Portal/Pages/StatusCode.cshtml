@page "/StatusCode/{code:int}"
@model StatusCodeModel
@{
    var is404 = Model.Code == 404;
    ViewData["Title"] = is404 ? "Halaman Tidak Ditemukan" : "Terjadi Kesalahan";
    Layout = "Tailwind/_LayoutBlank";
}

<div class="text-center py-6">
    <div class="text-[6rem] font-black leading-none mb-4" style="color: var(--primary); opacity: 0.15;">@Model.Code</div>

    @if (is404)
    {
        <h1 class="text-2xl font-semibold mb-2">Halaman Tidak Ditemukan</h1>
        <p class="text-muted-foreground text-sm mb-8 max-w-xs mx-auto">
            Halaman yang Anda cari mungkin telah dipindahkan, dihapus, atau URL-nya salah.
        </p>
    }
    else
    {
        <h1 class="text-2xl font-semibold mb-2">Terjadi Kesalahan</h1>
        <p class="text-muted-foreground text-sm mb-8 max-w-xs mx-auto">
            Server mengalami masalah saat memproses permintaan Anda. Silakan coba beberapa saat lagi.
        </p>
    }

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn btn-primary"><i class="ti ti-home"></i> Ke Beranda</a>
        <button type="button" data-action="back" class="btn btn-light"><i class="ti ti-arrow-left"></i> Kembali</button>
    </div>
</div>
