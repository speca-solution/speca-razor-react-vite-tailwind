@page
@model RegisterModel
@{
    ViewData["Title"] = "Daftar";
    Layout = "_LayoutBlank";
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScripts")
}

<div class="text-center mb-7">
    <div class="inline-flex size-11 items-center justify-center rounded-xl bg-primary text-primary-foreground text-xl font-bold mb-3">S</div>
    <h1 class="text-xl font-semibold tracking-tight">Buat Akun Baru</h1>
    <p class="text-muted-foreground text-sm mt-1">Bergabung dan mulai kelola aplikasi Anda</p>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" data-val="true" novalidate>
            @Html.AntiForgeryToken()
            @if (Model.ErrorMessage is not null)
            {
                <div class="alert alert-danger mb-4"><i class="ti ti-alert-triangle"></i><span>@Model.ErrorMessage</span></div>
            }
            <div class="flex flex-col gap-4">
                <div>
                    <label asp-for="Input.FullName" class="form-label">Nama Lengkap</label>
                    <input asp-for="Input.FullName" class="input" type="text" placeholder="John Doe" autocomplete="name" />
                    <span asp-validation-for="Input.FullName" class="field-validation-valid text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="input" type="email" placeholder="nama@email.com" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="field-validation-valid text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <div class="relative">
                        <input asp-for="Input.Password" id="regPwd" class="input pe-10" type="password" placeholder="Min. 8 karakter" autocomplete="new-password" />
                        <button type="button" class="absolute end-2.5 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-toggle-password="#regPwd" aria-label="Tampilkan password">
                            <i class="ti ti-eye text-base"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="field-validation-valid text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.ConfirmPassword" class="form-label">Konfirmasi Password</label>
                    <div class="relative">
                        <input asp-for="Input.ConfirmPassword" id="regCPwd" class="input pe-10" type="password" placeholder="Ulangi password" autocomplete="new-password" />
                        <button type="button" class="absolute end-2.5 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-toggle-password="#regCPwd" aria-label="Tampilkan konfirmasi password">
                            <i class="ti ti-eye text-base"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="field-validation-valid text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <div class="flex items-start gap-2">
                        <input asp-for="Input.AgreeTerms" id="agreeTerms" class="checkbox mt-0.5 shrink-0" type="checkbox" />
                        <label for="agreeTerms" class="text-sm cursor-pointer select-none leading-snug">
                            Saya menyetujui <a href="#" class="text-primary hover:underline">Syarat &amp; Ketentuan</a>
                            dan <a href="#" class="text-primary hover:underline">Kebijakan Privasi</a>
                        </label>
                    </div>
                    <span asp-validation-for="Input.AgreeTerms" class="field-validation-valid text-xs text-red-500 mt-1 block"></span>
                </div>

                <button type="submit" class="btn btn-primary w-full mt-1">
                    <i class="ti ti-user-plus"></i> Buat Akun
                </button>
            </div>
        </form>
    </div>
</div>

<p class="text-center text-sm text-muted-foreground mt-5">
    Sudah punya akun?
    <a href="/Account/Login" class="text-primary hover:underline font-medium">Masuk sekarang</a>
</p>
