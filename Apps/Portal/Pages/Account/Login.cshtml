@page
@model LoginModel
@{
    ViewData["Title"] = "Masuk";
    Layout = "Tailwind/_LayoutBlank";
}

@section Scripts {
    @await Html.PartialAsync("Tailwind/_ValidationScripts")
}

<div class="text-center mb-7">
    <div class="inline-flex size-11 items-center justify-center rounded-xl bg-primary text-primary-foreground text-xl font-bold mb-3">S</div>
    <h1 class="text-xl font-semibold tracking-tight">Selamat Datang Kembali</h1>
    <p class="text-muted-foreground text-sm mt-1">Masuk untuk melanjutkan ke Speca Platform</p>
</div>

<div class="card">
    <div class="card-body">
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger mb-4">
                <i class="ti ti-alert-circle text-lg"></i>
                <div>@err</div>
            </div>
        }

        <form method="post" data-val="true" novalidate>
            @Html.AntiForgeryToken()
            <div class="flex flex-col gap-4">
                <div>
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="input" type="email" placeholder="nama@email.com" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="field-validation-valid text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <div class="flex items-center justify-between mb-1.5">
                        <label asp-for="Input.Password" class="form-label mb-0">Password</label>
                        <a href="/Account/ForgotPassword" class="text-primary text-xs hover:underline">Lupa password?</a>
                    </div>
                    <div class="relative">
                        <input asp-for="Input.Password" id="loginPwd" class="input pe-10" type="password" placeholder="••••••••" autocomplete="current-password" />
                        <button type="button" class="absolute end-2.5 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-toggle-password="#loginPwd" aria-label="Tampilkan password">
                            <i class="ti ti-eye text-base"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="field-validation-valid text-xs text-red-500 mt-1 block"></span>
                </div>

                <div class="flex items-center gap-2">
                    <input asp-for="Input.RememberMe" id="rememberMe" class="checkbox" type="checkbox" />
                    <label for="rememberMe" class="form-label mb-0 text-sm cursor-pointer select-none">Ingat saya selama 30 hari</label>
                </div>

                <button type="submit" class="btn btn-primary w-full mt-1">
                    <i class="ti ti-login"></i> Masuk
                </button>
            </div>
        </form>

        <div class="relative my-5">
            <hr class="border-border" />
            <span class="absolute left-1/2 -translate-x-1/2 -top-2.5 bg-card px-3 text-muted-foreground text-xs">atau</span>
        </div>

        <div class="grid grid-cols-2 gap-2">
            <button type="button" class="btn btn-light justify-center gap-2 opacity-50 cursor-not-allowed" disabled title="Segera hadir">
                <i class="ti ti-brand-google text-base text-red-500"></i> Google
            </button>
            <button type="button" class="btn btn-light justify-center gap-2 opacity-50 cursor-not-allowed" disabled title="Segera hadir">
                <i class="ti ti-brand-github text-base"></i> GitHub
            </button>
        </div>
    </div>
</div>

<p class="text-center text-sm text-muted-foreground mt-5">
    Belum punya akun?
    <a href="/Account/Register" class="text-primary hover:underline font-medium">Daftar sekarang</a>
</p>
