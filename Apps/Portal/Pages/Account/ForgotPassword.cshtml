@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Lupa Password";
    Layout = "Tailwind/_LayoutBlank";
}

@section Scripts {
    @await Html.PartialAsync("Tailwind/_ValidationScripts")
}

<div class="text-center mb-7">
    <div class="inline-flex size-11 items-center justify-center rounded-xl bg-primary text-primary-foreground text-xl font-bold mb-3">S</div>
    @if (!Model.EmailSent)
    {
        <h1 class="text-xl font-semibold tracking-tight">Lupa Password?</h1>
        <p class="text-muted-foreground text-sm mt-1">Masukkan email Anda dan kami akan mengirimkan instruksi untuk mereset password.</p>
    }
    else
    {
        <h1 class="text-xl font-semibold tracking-tight">Cek Email Anda</h1>
        <p class="text-muted-foreground text-sm mt-1">Instruksi dikirimkan ke <strong>@Model.Input.Email</strong></p>
    }
</div>

<div class="card">
    <div class="card-body">
        @if (Model.EmailSent)
        {
            <div class="alert alert-success mb-5">
                <i class="ti ti-mail-check text-lg shrink-0"></i>
                <div>Email berhasil dikirim. Periksa kotak masuk dan folder spam Anda.</div>
            </div>
            <a href="/Account/Login" class="btn btn-primary w-full">
                <i class="ti ti-arrow-left"></i> Kembali ke Login
            </a>
        }
        else
        {
            <form method="post" data-val="true" novalidate>
                @Html.AntiForgeryToken()
                <div class="flex flex-col gap-4">
                    <div>
                        <label asp-for="Input.Email" class="form-label">Email Terdaftar</label>
                        <input asp-for="Input.Email" class="input" type="email" placeholder="nama@email.com" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="field-validation-valid text-xs text-red-500 mt-1 block"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-full mt-1">
                        <i class="ti ti-send"></i> Kirim Instruksi Reset
                    </button>
                </div>
            </form>

            <div class="mt-5 text-center">
                <a href="/Account/Login" class="text-sm text-muted-foreground hover:text-foreground inline-flex items-center gap-1.5">
                    <i class="ti ti-arrow-left text-sm"></i> Kembali ke Login
                </a>
            </div>
        }
    </div>
</div>
