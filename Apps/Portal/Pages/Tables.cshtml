@page
@model Speca.Portal.Pages.TablesModel
@using Speca.UI.Components
@using System.Text.Json
@{
    ViewData["Title"] = "Tabel Data";

    // Config Grid.js (sisi-klien): kolom + data diserialisasi sebagai JSON (CSP-safe).
    var gridConfig = new
    {
        columns = new[] { "Nama", "Kategori", "Harga", "Stok", "Status" },
        data = Model.AllForClient.Select(p => new object[]
        {
            p.Name, p.Category, $"Rp {p.Price:N0}", p.Stock, p.Active ? "Aktif" : "Nonaktif"
        }),
        pagination = new { limit = 10 },
    };
}

@section Breadcrumb {
    <div class="flex flex-wrap items-center justify-between gap-5 pb-7.5">
        <div class="flex flex-col gap-2">
            <h1 class="text-mono text-xl leading-none font-medium">Tabel Data</h1>
            <div class="text-secondary-foreground text-sm">
                Tiga pendekatan: server-side (0 KB), Grid.js (~14KB, no-jQuery), dan DataTables.net (jQuery scoped).
            </div>
        </div>
    </div>
}

<div class="card mb-10">
    <div class="card-header">
        <h3 class="card-title">Produk</h3>
        <form method="get" class="flex items-center gap-2">
            <input type="hidden" name="sort" value="@Model.Sort" />
            <input type="hidden" name="dir" value="@Model.Dir" />
            <label class="border-input flex h-9 w-56 items-center gap-2 rounded-md border px-3">
                <i class="ti ti-search text-muted-foreground"></i>
                <input type="text" name="q" value="@Model.Q"
                       class="placeholder:text-muted-foreground w-full bg-transparent text-sm outline-none"
                       placeholder="Cari nama/kategori..." />
            </label>
            <button type="submit" class="btn-outline">Cari</button>
        </form>
    </div>
    <div class="card-body overflow-x-auto pt-0">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>
                        <a class="hover:text-foreground inline-flex items-center gap-1" href="@Model.SortUrl("name")">
                            Nama <i class="@Model.SortIcon("name")"></i>
                        </a>
                    </th>
                    <th>Kategori</th>
                    <th>
                        <a class="hover:text-foreground inline-flex items-center gap-1" href="@Model.SortUrl("price")">
                            Harga <i class="@Model.SortIcon("price")"></i>
                        </a>
                    </th>
                    <th>
                        <a class="hover:text-foreground inline-flex items-center gap-1" href="@Model.SortUrl("stock")">
                            Stok <i class="@Model.SortIcon("stock")"></i>
                        </a>
                    </th>
                    <th>Status</th>
                    <th class="text-end">Aksi</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="text-mono font-medium">@item.Name</td>
                        <td class="text-secondary-foreground">@item.Category</td>
                        <td class="text-mono">Rp @item.Price.ToString("N0")</td>
                        <td>@item.Stock</td>
                        <td>
                            @if (item.Active)
                            {
                                <span class="badge badge-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">Nonaktif</span>
                            }
                        </td>
                        <td class="text-end">
                            <button type="button" class="btn-icon size-7" data-tooltip="Edit"><i class="ti ti-pencil text-sm"></i></button>
                            <button type="button" class="btn-icon size-7" data-tooltip="Hapus"
                                    data-toast="Demo: hapus @item.Name" data-toast-variant="danger">
                                <i class="ti ti-trash text-sm"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-muted-foreground py-10 text-center">
                            Tidak ada data untuk "@Model.Q".
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="flex flex-wrap items-center justify-between gap-3 pt-4">
            <span class="text-muted-foreground text-sm">
                Menampilkan @Model.From–@Model.To dari @Model.Total
            </span>
            <partial name="Tailwind/_Pagination"
                     model="new PaginationViewModel(Model.P, Model.TotalPages, Model.PageUrl)" />
        </div>
    </div>
</div>

<!-- =====================================================================
     Grid.js — datatable interaktif tanpa jQuery (~14KB), vendor opsional.
     Config (kolom + data) via JSON inline; tema ikut token Speca + dark mode.
     ===================================================================== -->
<div class="card mb-10">
    <div class="card-header">
        <h3 class="card-title">Grid.js (sisi-klien, no-jQuery)</h3>
        <span class="text-muted-foreground text-xs">search · sort · paginate bawaan library</span>
    </div>
    <div class="card-body">
        <div data-gridjs>
            <script type="application/json">@Html.Raw(JsonSerializer.Serialize(gridConfig))</script>
        </div>
    </div>
</div>

<!-- =====================================================================
     DataTables.net — fitur lengkap (responsive, select, export copy/csv/print).
     jQuery di-BUNDLE hanya ke dalam chunk vendor ini (tidak ke layout/halaman lain).
     ===================================================================== -->
<div class="card mb-10">
    <div class="card-header">
        <h3 class="card-title">DataTables.net (jQuery scoped)</h3>
        <span class="text-muted-foreground text-xs">responsive · select · export copy/csv/print</span>
    </div>
    <div class="card-body overflow-x-auto">
        <div data-datatables>
            <script type="application/json">{ "pageLength": 10 }</script>
            <table class="table" style="width:100%">
                <thead>
                    <tr>
                        <th>Nama</th>
                        <th>Kategori</th>
                        <th>Harga</th>
                        <th>Stok</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.AllForClient)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Category</td>
                            <td>Rp @item.Price.ToString("N0")</td>
                            <td>@item.Stock</td>
                            <td>@(item.Active ? "Aktif" : "Nonaktif")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <vite-asset src="Libs/UI/Assets/Vendors/gridjs/index.js" />
    <vite-asset src="Libs/UI/Assets/Vendors/datatables/index.js" />
}
