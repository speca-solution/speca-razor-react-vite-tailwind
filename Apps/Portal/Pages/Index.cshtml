@page

@model IndexModel

@{
    ViewData["Title"] = "Home page";
}

@section Breadcrumb {
    <div class="flex flex-wrap items-center justify-between gap-5 pb-7.5 lg:items-end">
        <div class="flex flex-col justify-center gap-2">
            <h1 class="text-mono text-xl leading-none font-medium">
                Dashboard
            </h1>
            <div class="text-secondary-foreground flex items-center gap-2 text-sm font-normal">
                Central Hub for Personal Customization
            </div>
        </div>
        <div class="flex items-center gap-2.5">
            <a class="btn-outline" href="#">
                View Profile
            </a>
        </div>
    </div>
}

@await Html.PartialAsync("_DemoWidgets")

@* Pola Razor → React: model server di-serialize ke data-attribute,
   main.tsx membacanya dan meneruskan sebagai props saat hydrate. *@
<div class="mt-5 mb-10 grid gap-5 xl:grid-cols-3">
    <div id="root" data-initial="@Model.DataJson">
        <div class="text-muted-foreground p-10">Inisialisasi aplikasi...</div>
    </div>
</div>

@section Scripts {
    <vite-entry src="Apps/Portal/Assets/Entries/main.tsx" />
}
