@page
@using Speca.Portal
@{
    ViewData["Title"] = Speca.Core.BuildFlags.IsStarter ? "Beranda" : "Preview Theme";
    var dashboard = ThemeInfo.All.FirstOrDefault();
}

@section Breadcrumb {
    <div class="flex flex-col gap-2 pb-7.5">
        <h1 class="text-mono text-xl leading-none font-medium">@ViewData["Title"]</h1>
        <div class="text-secondary-foreground text-sm">
            @if (Speca.Core.BuildFlags.IsStarter)
            {
                <text>Titik awal ramping — kembangkan halaman Anda dari sini.</text>
            }
            else
            {
                <text>
                    Halaman yang sama di tiap tema yang tersedia — bukti halaman theme-agnostic
                    (satu sumber, banyak tampilan).
                </text>
            }
        </div>
    </div>
}

@if (Speca.Core.BuildFlags.IsStarter)
{
    <!-- ───────── Home varian STARTER: sambutan ringkas + pintasan ───────── -->
    <div class="card card-body mb-5">
        <h2 class="text-mono text-2xl font-semibold mb-2">Selamat datang 👋</h2>
        <p class="text-secondary-foreground max-w-2xl">
            Ini titik awal aplikasi Anda — Razor Pages (.NET 10) + Vite/Rolldown + React 19 +
            Tailwind CSS 4 + TypeScript. Komponen UI di <code>Libs/UI</code> siap dipakai;
            tambahkan halaman baru di <code>Pages/</code>.
        </p>
        <div class="flex flex-wrap gap-3 mt-5">
            @if (dashboard is not null)
            {
                <a class="btn btn-primary" href="@dashboard.DashboardPath">
                    <i class="ti ti-layout-dashboard"></i> Buka Dashboard
                </a>
            }
            <a class="btn btn-light" href="/Account/Login"><i class="ti ti-login"></i> Halaman Login</a>
            <a class="btn btn-light" href="https://tailwindcss.com/docs" target="_blank" rel="noopener">
                <i class="ti ti-book"></i> Dokumentasi Tailwind
            </a>
        </div>
    </div>

    <div class="grid gap-5 md:grid-cols-3">
        <div class="card card-body">
            <i class="ti ti-components text-primary text-2xl mb-2"></i>
            <h3 class="card-title mb-1">Komponen siap pakai</h3>
            <p class="text-secondary-foreground text-sm">Button, form, modal, tabel, dropdown, dll. dari <code>Libs/UI</code>.</p>
        </div>
        <div class="card card-body">
            <i class="ti ti-brand-react text-primary text-2xl mb-2"></i>
            <h3 class="card-title mb-1">React island</h3>
            <p class="text-secondary-foreground text-sm">Sisipkan komponen React di halaman Razor lewat entry Vite.</p>
        </div>
        <div class="card card-body">
            <i class="ti ti-palette text-primary text-2xl mb-2"></i>
            <h3 class="card-title mb-1">Tema + dark mode</h3>
            <p class="text-secondary-foreground text-sm">Tailwind 4 dengan token tema; dark mode runtime untuk pengguna.</p>
        </div>
    </div>
}
else
{
    <partial name="_HomePreview" />
}
