@page
@model Speca.Portal.Pages.ComponentsModel
@{
    ViewData["Title"] = "Components";
}

@section Breadcrumb {
    <div class="flex flex-wrap items-center justify-between gap-5 pb-7.5">
        <div class="flex flex-col gap-2">
            <h1 class="text-mono text-xl leading-none font-medium">Components</h1>
            <div class="text-secondary-foreground text-sm">Galeri komponen dasar — form, modal, toast, tabs.</div>
        </div>
    </div>
}

@if (Model.SuccessMessage is not null)
{
    <div class="card mb-5">
        <div class="card-body flex items-center gap-2 pt-5 text-sm text-green-600 dark:text-green-400">
            <i class="ti ti-check"></i> @Model.SuccessMessage
        </div>
    </div>
}

<div class="grid gap-5 xl:grid-cols-2">

    <!-- Form + validasi client-side -->
    <div class="card">
        <div class="card-header"><h3 class="card-title">Form & Validasi (tanpa jQuery)</h3></div>
        <div class="card-body">
            <form method="post" class="flex flex-col gap-4" novalidate>
                <div>
                    <label class="form-label" asp-for="Form.Name"></label>
                    <input class="input" asp-for="Form.Name" placeholder="Nama lengkap" />
                    <span asp-validation-for="Form.Name"></span>
                </div>
                <div>
                    <label class="form-label" asp-for="Form.Email"></label>
                    <input class="input" asp-for="Form.Email" placeholder="nama@contoh.id" />
                    <span asp-validation-for="Form.Email"></span>
                    <span class="form-hint">Validasi DataAnnotations berjalan di browser sebelum submit.</span>
                </div>
                <div>
                    <label class="form-label" asp-for="Form.Role"></label>
                    <select class="select" asp-for="Form.Role">
                        <option value="">— pilih —</option>
                        <option>Admin</option>
                        <option>Editor</option>
                        <option>Viewer</option>
                    </select>
                    <span asp-validation-for="Form.Role"></span>
                </div>
                <div>
                    <label class="form-label" asp-for="Form.Notes"></label>
                    <textarea class="textarea" asp-for="Form.Notes" placeholder="Opsional"></textarea>
                    <span asp-validation-for="Form.Notes"></span>
                </div>
                <div>
                    <label class="form-label" asp-for="Form.CardNumber"></label>
                    <input class="input" asp-for="Form.CardNumber" placeholder="4111 1111 1111 1111" />
                    <span asp-validation-for="Form.CardNumber"></span>
                    <span class="form-hint">Validator Luhn berjalan client-side dari atribut [CreditCard] C#.</span>
                </div>
                <div class="flex items-center gap-6">
                    <label class="flex cursor-pointer items-center gap-2 text-sm">
                        <input type="checkbox" class="switch" asp-for="Form.IsActive" />
                        Aktif (switch)
                    </label>
                    <label class="flex cursor-pointer items-center gap-2 text-sm">
                        <input type="checkbox" class="checkbox" checked /> Checkbox
                    </label>
                    <label class="flex cursor-pointer items-center gap-2 text-sm">
                        <input type="radio" class="radio" name="r1" checked /> Radio
                    </label>
                </div>
                <div class="flex gap-3 pt-1">
                    <button type="submit" class="btn btn-primary">
                        Submit
                    </button>
                    <button type="reset" class="btn-outline">Reset</button>
                </div>
            </form>
        </div>
    </div>

    <div class="flex flex-col gap-5">
        <!-- Modal -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">Modal (&lt;dialog&gt; native)</h3></div>
            <div class="card-body flex gap-3">
                <button type="button" class="btn btn-primary"
                        data-modal-open="#demo_modal">
                    Buka Modal
                </button>
                <button type="button" class="btn-outline" data-modal-open="#confirm_modal">
                    Pola Confirm
                </button>
            </div>
        </div>

        <!-- Toast -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">Toast</h3></div>
            <div class="card-body flex flex-wrap gap-2">
                <button type="button" class="btn-outline" onclick="specaToast('Data tersimpan.', 'success')">Success</button>
                <button type="button" class="btn-outline" onclick="specaToast('Periksa kembali input Anda.', 'warning')">Warning</button>
                <button type="button" class="btn-outline" onclick="specaToast('Terjadi kesalahan server.', 'danger')">Danger</button>
                <button type="button" class="btn-outline" onclick="specaToast('Info biasa.')">Default</button>
            </div>
        </div>

        <!-- Tabs -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">Tabs</h3></div>
            <div class="card-body">
                <div class="border-border flex gap-1 border-b" data-tabs>
                    <button type="button" class="tab-toggle tab-active" data-tab-target="#tab_profil">Profil</button>
                    <button type="button" class="tab-toggle" data-tab-target="#tab_keamanan">Keamanan</button>
                    <button type="button" class="tab-toggle" data-tab-target="#tab_notif">Notifikasi</button>
                </div>
                <div class="pt-4 text-sm">
                    <div id="tab_profil">Konten tab <b>Profil</b>.</div>
                    <div id="tab_keamanan" class="hidden">Konten tab <b>Keamanan</b>.</div>
                    <div id="tab_notif" class="hidden">Konten tab <b>Notifikasi</b>.</div>
                </div>
            </div>
        </div>

        <!-- Tooltip & Drawer -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">Tooltip & Drawer</h3></div>
            <div class="card-body flex flex-wrap gap-3">
                <button type="button" class="btn-outline" data-tooltip="Tooltip CSS murni, tanpa JS">Hover saya</button>
                <button type="button" class="btn-outline" data-tooltip="Posisi bawah" data-tooltip-pos="bottom">Tooltip bawah</button>
                <button type="button" class="btn btn-primary"
                        data-drawer-open="#demo_drawer">
                    Buka Drawer
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Primitif kecil -->
<div class="card mt-5">
    <div class="card-header"><h3 class="card-title">Primitif</h3></div>
    <div class="card-body grid gap-6 lg:grid-cols-2">
        <div class="flex flex-col gap-2.5">
            <div class="alert alert-primary"><i class="ti ti-info-circle"></i> Alert primary — informasi umum.</div>
            <div class="alert alert-success"><i class="ti ti-check"></i> Alert success — aksi berhasil.</div>
            <div class="alert alert-warning"><i class="ti ti-alert-triangle"></i> Alert warning — perlu perhatian.</div>
            <div class="alert alert-danger"><i class="ti ti-x"></i> Alert danger — terjadi kesalahan.</div>
        </div>
        <div class="flex flex-col gap-5">
            <div>
                <div class="text-secondary-foreground mb-1.5 flex justify-between text-sm"><span>Progress</span><span>72%</span></div>
                <div class="progress"><div class="progress-bar" style="width: 72%"></div></div>
            </div>
            <div class="flex items-center gap-4">
                <span class="spinner text-primary"></span>
                <span class="avatar size-9 text-sm">AS</span>
                <span class="avatar size-9 bg-green-600 text-sm">RD</span>
                <div class="skeleton h-9 w-28"></div>
            </div>
            <nav class="pagination">
                <a class="page-link" href="#"><i class="ti ti-chevron-left"></i></a>
                <a class="page-link" href="#">1</a>
                <a class="page-link active" href="#">2</a>
                <a class="page-link" href="#">3</a>
                <a class="page-link" href="#"><i class="ti ti-chevron-right"></i></a>
            </nav>
            <div class="divider">atau</div>
        </div>
    </div>
</div>

<!-- Primitif lanjutan (E6-12) -->
<div class="card mt-5">
    <div class="card-header"><h3 class="card-title">Primitif Lanjutan</h3></div>
    <div class="card-body grid gap-6 lg:grid-cols-2">
        <div class="flex flex-col gap-5">
            <div>
                <div class="form-label">Breadcrumb (partial reusable)</div>
                <partial name="Tailwind/_Breadcrumb"
                         model="@(new List<Speca.UI.Components.BreadcrumbItem> { new("Home", "/"), new("Komponen", "/Components"), new("Primitif") })" />
            </div>
            <div>
                <div class="form-label">Kbd & Button Group</div>
                <div class="flex flex-wrap items-center gap-4">
                    <span class="text-secondary-foreground text-sm">Tekan <span class="kbd">Ctrl</span> + <span class="kbd">/</span></span>
                    <div class="btn-group">
                        <button type="button" class="btn-outline">Kiri</button>
                        <button type="button" class="btn-outline">Tengah</button>
                        <button type="button" class="btn-outline">Kanan</button>
                    </div>
                </div>
            </div>
            <div class="flex flex-wrap items-end gap-5">
                <div>
                    <div class="form-label">Input Number</div>
                    <div class="input-number" data-stepper>
                        <button type="button" data-stepper-down aria-label="Kurang"><i class="ti ti-minus text-sm"></i></button>
                        <input type="number" value="2" min="0" max="10" />
                        <button type="button" data-stepper-up aria-label="Tambah"><i class="ti ti-plus text-sm"></i></button>
                    </div>
                </div>
                <div>
                    <div class="form-label">Rating</div>
                    <div class="rating" data-rating>
                        <input type="hidden" name="score" value="3" />
                        <button type="button"><i class="ti ti-star"></i></button>
                        <button type="button"><i class="ti ti-star"></i></button>
                        <button type="button"><i class="ti ti-star"></i></button>
                        <button type="button"><i class="ti ti-star"></i></button>
                        <button type="button"><i class="ti ti-star"></i></button>
                    </div>
                </div>
            </div>
            <div>
                <div class="form-label">Toggle Password</div>
                <div class="relative max-w-60">
                    <input class="input pe-10" type="password" id="demo_password" value="rahasia123" />
                    <button type="button" class="btn-icon absolute end-0 top-0 size-9"
                            data-toggle-password="#demo_password" aria-label="Lihat password">
                        <i class="ti ti-eye text-base"></i>
                    </button>
                </div>
            </div>
            <div>
                <div class="form-label">Popover (klik)</div>
                <div class="relative inline-block">
                    <button type="button" class="btn-outline" data-dropdown-toggle="#demo_popover">Buka popover</button>
                    <div id="demo_popover" class="popover hidden">
                        <div class="popover-title">Judul Popover</div>
                        <div class="popover-body">Konten kaya — bisa berisi teks, link, atau form kecil.</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="flex flex-col gap-5">
            <div>
                <div class="form-label">Accordion (single-open)</div>
                <div class="accordion" data-accordion="single">
                    <details class="accordion-item" open>
                        <summary>Apa itu Speca Platform? <i class="menu-chevron ti ti-chevron-down text-muted-foreground text-xs transition-transform"></i></summary>
                        <div class="accordion-body">Template Razor Pages + Vite + React + Tailwind 4.</div>
                    </details>
                    <details class="accordion-item">
                        <summary>Apakah theme bisa diganti? <i class="menu-chevron ti ti-chevron-down text-muted-foreground text-xs transition-transform"></i></summary>
                        <div class="accordion-body">Ya — theme1/theme2 via ViewData, dark mode via toggle.</div>
                    </details>
                    <details class="accordion-item">
                        <summary>Lisensinya aman? <i class="menu-chevron ti ti-chevron-down text-muted-foreground text-xs transition-transform"></i></summary>
                        <div class="accordion-body">Semua bundel MIT/ISC; Metronic & Vuexy hanya referensi desain.</div>
                    </details>
                </div>
            </div>
            <div>
                <div class="form-label">Timeline</div>
                <div class="timeline">
                    <div class="timeline-item"><div class="text-sm">Order dibuat</div><div class="text-muted-foreground text-xs">09:00</div></div>
                    <div class="timeline-item timeline-item-success"><div class="text-sm">Pembayaran diterima</div><div class="text-muted-foreground text-xs">09:05</div></div>
                    <div class="timeline-item timeline-item-warning"><div class="text-sm">Menunggu pengiriman</div><div class="text-muted-foreground text-xs">10:30</div></div>
                </div>
            </div>
            <div>
                <div class="form-label">BlockUI (loading overlay)</div>
                <div id="block_target" class="border-border relative rounded-lg border p-4 text-sm">
                    Konten panel yang bisa diblokir saat memuat data.
                    <div class="mt-3 flex gap-2">
                        <button type="button" class="btn-sm btn-primary"
                                onclick="specaBlock('#block_target', true); setTimeout(() => specaBlock('#block_target', false), 2000)">
                            Block 2 detik
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Form & data (Tier 1+2, tanpa vendor) -->
<div class="card mt-5">
    <div class="card-header"><h3 class="card-title">Form Lanjutan</h3></div>
    <div class="card-body grid gap-6 lg:grid-cols-2">
        <div class="flex flex-col gap-5">
            <div>
                <div class="form-label">Input Group / Addon</div>
                <div class="flex flex-col gap-2.5">
                    <div class="input-group max-w-xs">
                        <span class="input-group-text">@@</span>
                        <input class="input" placeholder="username" />
                    </div>
                    <div class="input-group max-w-xs">
                        <span class="input-group-text"><i class="ti ti-currency-dollar text-sm"></i></span>
                        <input class="input" placeholder="0,00" />
                        <span class="input-group-text">IDR</span>
                    </div>
                </div>
            </div>
            <div data-range-wrap>
                <div class="mb-1.5 flex items-center justify-between">
                    <span class="form-label mb-0">Range Slider</span>
                    <span class="text-foreground text-sm font-medium" data-range-value>40</span>
                </div>
                <input type="range" class="range" min="0" max="100" value="40" />
            </div>
            <div>
                <div class="form-label">OTP / PIN</div>
