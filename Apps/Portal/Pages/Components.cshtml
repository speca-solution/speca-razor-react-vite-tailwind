<!-- Wizard + repeater -->
<div class="card mt-5">
    <div class="card-header"><h3 class="card-title">Form Wizard & Repeater</h3></div>
    <div class="card-body grid gap-8 lg:grid-cols-2">
        <div data-wizard>
            <div class="form-label">Wizard (multi-step)</div>
            <div class="wizard-nav mt-2 mb-6">
                <div class="wizard-step"><span class="wizard-step-circle">1</span><span class="wizard-step-label">Akun</span></div>
                <div class="wizard-step-line"></div>
                <div class="wizard-step"><span class="wizard-step-circle">2</span><span class="wizard-step-label">Profil</span></div>
                <div class="wizard-step-line"></div>
                <div class="wizard-step"><span class="wizard-step-circle">3</span><span class="wizard-step-label">Selesai</span></div>
            </div>
            <div data-wizard-pane class="flex flex-col gap-3">
                <input class="input" placeholder="Email" />
                <input class="input" type="password" placeholder="Password" />
            </div>
            <div data-wizard-pane class="hidden flex-col gap-3">
                <input class="input" placeholder="Nama lengkap" />
                <input class="input" placeholder="No. telepon" />
            </div>
            <div data-wizard-pane class="hidden">
                <div class="alert alert-success"><i class="ti ti-check"></i> Semua langkah selesai — siap dikirim.</div>
            </div>
            <div class="mt-5 flex justify-between">
                <button type="button" class="btn-outline" data-wizard-prev>Kembali</button>
                <button type="button" class="btn btn-primary" data-wizard-next>Lanjut</button>
            </div>
        </div>
        <div data-repeater>
            <div class="form-label">Repeater (baris dinamis)</div>
            <div data-repeater-list class="mt-2 flex flex-col gap-2.5">
                <div data-repeater-item class="flex gap-2">
                    <input class="input" placeholder="Nama item" />
                    <input class="input max-w-24" placeholder="Qty" />
                    <button type="button" class="btn-icon shrink-0" data-repeater-remove aria-label="Hapus baris"><i class="ti ti-trash text-sm"></i></button>
                </div>
            </div>
            <template data-repeater-template>
                <div data-repeater-item class="flex gap-2">
                    <input class="input" placeholder="Nama item" />
                    <input class="input max-w-24" placeholder="Qty" />
                    <button type="button" class="btn-icon shrink-0" data-repeater-remove aria-label="Hapus baris"><i class="ti ti-trash text-sm"></i></button>
                </div>
            </template>
            <button type="button" class="btn-outline btn-sm mt-3" data-repeater-add><i class="ti ti-plus text-sm"></i> Tambah baris</button>
        </div>
    </div>
</div>

