                    <label class="option-card">
                        <input type="radio" name="plan_demo" class="radio mt-0.5" />
                        <span>
                            <span class="text-foreground block font-medium">Pro</span>
                            <span class="text-muted-foreground text-sm">Rp149rb / bulan — semua fitur.</span>
                        </span>
                    </label>
                </div>
            </div>
            <div>
                <div class="form-label">List Group</div>
                <div class="list-group max-w-xs">
                    <a href="#" class="list-group-item"><i class="ti ti-inbox"></i> Kotak Masuk <span class="badge badge-primary ms-auto">12</span></a>
                    <a href="#" class="list-group-item active"><i class="ti ti-send"></i> Terkirim</a>
                    <a href="#" class="list-group-item"><i class="ti ti-file"></i> Draf</a>
                    <span class="list-group-item disabled"><i class="ti ti-trash"></i> Sampah</span>
                </div>
            </div>
        </div>
    </div>
</div>

