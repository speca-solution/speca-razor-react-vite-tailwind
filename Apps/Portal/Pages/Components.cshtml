<!-- Dropzone -->
<div class="card mt-5">
    <div class="card-header"><h3 class="card-title">File Dropzone (multi-file)</h3></div>
    <div class="card-body">
        <div data-dropzone class="max-w-xl">
            <div class="dropzone">
                <i class="ti ti-cloud-upload text-3xl"></i>
                <div class="text-sm">Seret file ke sini atau <span class="text-primary font-medium">klik untuk memilih</span></div>
                <div class="text-xs">Mendukung banyak file sekaligus</div>
            </div>
            <input type="file" multiple class="hidden" aria-label="Pilih file" />
            <div data-dropzone-list></div>
        </div>
    </div>
</div>

<!-- Vendor opsional: hanya dimuat halaman ini -->
<div class="card mt-5 mb-10">
    <div class="card-header">
        <h3 class="card-title">Vendor Opsional (dimuat per halaman)</h3>
        <span class="text-muted-foreground text-xs">Tom Select · flatpickr · ApexCharts · Quill · Pickr · SortableJS — bukan di layout</span>
    </div>
    <div class="card-body grid gap-4 lg:grid-cols-2">
        <div>
            <label class="form-label">Multi-select + search (Tom Select)</label>
            <select multiple data-tom-select placeholder="Pilih beberapa...">
                <option value="id">Indonesia</option>
                <option value="my">Malaysia</option>
                <option value="sg">Singapura</option>
                <option value="th">Thailand</option>
                <option value="vn">Vietnam</option>
            </select>
        </div>
        <div>
            <label class="form-label">Tanggal (flatpickr)</label>
            <input class="input" data-flatpickr placeholder="Pilih tanggal..." />
        </div>
        <div>
            <label class="form-label">Color picker (Pickr)</label>
            <div><button type="button" data-color-picker data-default="#1b84ff"></button></div>
        </div>
        <div>
            <label class="form-label">Drag &amp; drop (SortableJS)</label>
            <ul class="list-group" data-sortable>
                <li class="list-group-item"><i class="ti ti-grip-vertical text-muted-foreground cursor-move"></i> Tarik untuk mengurutkan — satu</li>
                <li class="list-group-item"><i class="ti ti-grip-vertical text-muted-foreground cursor-move"></i> Item dua</li>
                <li class="list-group-item"><i class="ti ti-grip-vertical text-muted-foreground cursor-move"></i> Item tiga</li>
            </ul>
        </div>
        <div class="lg:col-span-2">
            <label class="form-label">Rich text editor (Quill)</label>
            <div data-quill data-quill-placeholder="Tulis konten di sini..."></div>
        </div>
    </div>
</div>

@section EndOfPage {
    <dialog class="modal" id="demo_modal">
        <div class="modal-header">
            <h3 class="card-title">Judul Modal</h3>
            <button type="button" class="btn-icon" data-modal-dismiss aria-label="Tutup">
                <i class="ti ti-x"></i>
            </button>
        </div>
        <div class="modal-body text-secondary-foreground text-sm">
            Modal memakai elemen <code>&lt;dialog&gt;</code> native — focus-trap & Esc dibawa browser.
            Klik backdrop juga menutup.
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-outline" data-modal-dismiss>Tutup</button>
        </div>
    </dialog>

    <aside class="drawer" id="demo_drawer" aria-label="Filter">
        <div class="drawer-header">
            <h3 class="card-title">Filter</h3>
            <button type="button" class="btn-icon" data-drawer-dismiss aria-label="Tutup">
                <i class="ti ti-x"></i>
            </button>
        </div>
        <div class="drawer-body flex flex-col gap-4">
            <div>
                <label class="form-label">Status</label>
                <select class="select">
                    <option>Semua</option>
                    <option>Aktif</option>
                    <option>Nonaktif</option>
                </select>
            </div>
            <div>
                <label class="form-label">Kata kunci</label>
                <input class="input" placeholder="Cari..." />
            </div>
            <button type="button" class="btn btn-primary"
                    data-drawer-dismiss onclick="specaToast('Filter diterapkan (demo).', 'success')">
                Terapkan
            </button>
        </div>
    </aside>

    <dialog class="modal" id="confirm_modal">
        <div class="modal-header">
            <h3 class="card-title">Hapus data?</h3>
        </div>
        <div class="modal-body text-secondary-foreground text-sm">
            Tindakan ini tidak bisa dibatalkan.
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-outline" data-modal-dismiss>Batal</button>
            <button type="button" class="btn btn-danger"
                    data-modal-dismiss="confirm"
                    onclick="specaToast('Data dihapus (demo).', 'danger')">
                Hapus
            </button>
        </div>
    </dialog>
}

