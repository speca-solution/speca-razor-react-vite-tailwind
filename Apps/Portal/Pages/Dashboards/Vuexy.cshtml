@page
@{
    ViewData["Title"] = "Dashboard — Vuexy";
    @* Komposisi ala Vuexy: welcome card + stat warna-warni + radial. Pin theme2. *@
    ViewData["Style"] = "style02";
}

@section Breadcrumb {
    <div class="flex flex-wrap items-center justify-between gap-5 pb-7.5 lg:items-end">
        <div class="flex flex-col gap-2">
            <h1 class="text-mono text-xl leading-none font-medium">Dashboard</h1>
            <div class="text-secondary-foreground text-sm">Komposisi referensi Vuexy — rasa theme2</div>
        </div>
        <a class="btn-outline" href="/?page=vuexy">Bandingkan theme</a>
    </div>
}

<!-- Welcome card + Goal radial -->
<div class="grid gap-5 xl:grid-cols-3">
    <div class="card xl:col-span-2 overflow-hidden">
        <div class="card-body relative flex items-center justify-between gap-4">
            <div class="max-w-sm">
                <h2 class="text-mono mb-1 text-lg font-semibold">Selamat datang, Speca Admin 🎉</h2>
                <p class="text-secondary-foreground mb-4 text-sm">
                    Penjualan Anda <span class="text-primary font-semibold">naik 24%</span> dibanding bulan lalu.
                    Tetap pertahankan!
                </p>
                <a href="#" class="btn btn-primary"><i class="ti ti-eye"></i> Lihat ringkasan</a>
            </div>
            <i class="ti ti-rocket text-primary/20 hidden text-[7rem] leading-none sm:block"></i>
        </div>
    </div>
    <div class="card">
        <div class="card-header"><h3 class="card-title">Target Bulanan</h3></div>
        <div class="card-body">
            <div data-apexchart>
                <script type="application/json">
                {
                    "chart": { "type": "radialBar", "height": 260 },
                    "series": [68],
                    "labels": ["Tercapai"],
                    "plotOptions": { "radialBar": { "hollow": { "size": "62%" }, "dataLabels": { "value": { "fontSize": "1.5rem" } } } }
                }
                </script>
            </div>
        </div>
    </div>
</div>

<!-- Stat warna-warni (ciri Vuexy) -->
<div class="mt-5 grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
    <div class="card card-body flex items-center gap-4">
        <span class="inline-flex size-11 shrink-0 items-center justify-center rounded-md bg-primary/10 text-primary text-xl"><i class="ti ti-credit-card"></i></span>
        <div>
            <div class="text-mono text-xl font-bold">Rp 52,4 jt</div>
            <div class="text-muted-foreground text-2sm">Pendapatan</div>
        </div>
    </div>
    <div class="card card-body flex items-center gap-4">
        <span class="inline-flex size-11 shrink-0 items-center justify-center rounded-md bg-green-500/10 text-green-600 text-xl"><i class="ti ti-shopping-bag"></i></span>
        <div>
            <div class="text-mono text-xl font-bold">1.235</div>
            <div class="text-muted-foreground text-2sm">Order</div>
        </div>
    </div>
    <div class="card card-body flex items-center gap-4">
        <span class="inline-flex size-11 shrink-0 items-center justify-center rounded-md bg-amber-500/10 text-amber-600 text-xl"><i class="ti ti-users"></i></span>
        <div>
            <div class="text-mono text-xl font-bold">892</div>
            <div class="text-muted-foreground text-2sm">Pelanggan</div>
        </div>
    </div>
    <div class="card card-body flex items-center gap-4">
        <span class="inline-flex size-11 shrink-0 items-center justify-center rounded-md bg-sky-500/10 text-sky-600 text-xl"><i class="ti ti-chart-line"></i></span>
        <div>
            <div class="text-mono text-xl font-bold">4,6%</div>
            <div class="text-muted-foreground text-2sm">Konversi</div>
        </div>
    </div>
</div>

<!-- Revenue area + Transaksi terbaru -->
<div class="mt-5 mb-10 grid gap-5 xl:grid-cols-3">
    <div class="card xl:col-span-2">
        <div class="card-header">
            <h3 class="card-title">Pendapatan</h3>
            <span class="badge badge-success"><i class="ti ti-trending-up"></i> +24%</span>
        </div>
        <div class="card-body">
            <div data-apexchart>
                <script type="application/json">
                {
                    "chart": { "type": "area", "height": 300, "toolbar": { "show": false } },
                    "series": [{ "name": "Pendapatan", "data": [28, 45, 35, 60, 48, 72, 65] }],
                    "xaxis": { "categories": ["Sen","Sel","Rab","Kam","Jum","Sab","Min"] },
                    "dataLabels": { "enabled": false },
                    "stroke": { "curve": "smooth", "width": 3 },
                    "fill": { "type": "gradient", "gradient": { "opacityFrom": 0.5, "opacityTo": 0.05 } }
                }
                </script>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-header"><h3 class="card-title">Transaksi Terbaru</h3></div>
        <div class="card-body flex flex-col gap-3.5 pt-1">
            <div class="flex items-center gap-3">
                <span class="inline-flex size-9 shrink-0 items-center justify-center rounded-full bg-green-500/10 text-green-600"><i class="ti ti-arrow-down-left"></i></span>
                <div class="grow"><div class="text-sm font-medium">Pembayaran masuk</div><div class="text-muted-foreground text-xs">Budi Santoso</div></div>
                <span class="text-mono text-sm font-semibold text-green-600">+Rp 1,25 jt</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="inline-flex size-9 shrink-0 items-center justify-center rounded-full bg-red-500/10 text-red-600"><i class="ti ti-arrow-up-right"></i></span>
                <div class="grow"><div class="text-sm font-medium">Refund</div><div class="text-muted-foreground text-xs">Andi Wijaya</div></div>
                <span class="text-mono text-sm font-semibold text-red-600">-Rp 2,10 jt</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="inline-flex size-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary"><i class="ti ti-wallet"></i></span>
                <div class="grow"><div class="text-sm font-medium">Top up saldo</div><div class="text-muted-foreground text-xs">Siti Aminah</div></div>
                <span class="text-mono text-sm font-semibold text-green-600">+Rp 480 rb</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="inline-flex size-9 shrink-0 items-center justify-center rounded-full bg-amber-500/10 text-amber-600"><i class="ti ti-clock"></i></span>
                <div class="grow"><div class="text-sm font-medium">Menunggu konfirmasi</div><div class="text-muted-foreground text-xs">Dewi Lestari</div></div>
                <span class="text-mono text-sm font-semibold text-amber-600">Rp 760 rb</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <vite-asset src="Libs/UI/Assets/Vendors/apexcharts/index.js" />
}
