{
  "$schema": "http://json.schemastore.org/template",
  "author": "Speca",
  "classifications": [ "Web", "Razor Pages", "React", "Tailwind", "Vite", "Solution" ],
  "identity": "Speca.Template.Solution.CSharp",
  "name": "Speca Template Solution (Razor Pages + Vite + React + Tailwind + TypeScript)",
  "description": "Solution monorepo ASP.NET Core Razor Pages (.NET 10) + Vite 8/Rolldown + React 19 + Tailwind 4 + TypeScript, dengan pnpm workspaces (Apps/* aplikasi, Libs/* library). Nama solution & nama project aplikasi dapat diganti saat instantiate.",
  "shortName": "speca-template",
  "defaultName": "MyApp",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "Speca",
  "symbols": {
    "AppName": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "Portal",
      "replaces": "Portal",
      "fileRename": "Portal",
      "description": "Nama project aplikasi web (folder Apps/<AppName> dan namespace <Solution>.<AppName>). Default: Portal."
    },
    "nameLower": {
      "type": "generated",
      "generator": "casing",
      "parameters": { "source": "name", "toLower": true },
      "replaces": "speca",
      "fileRename": "speca"
    },
    "nameUpper": {
      "type": "generated",
      "generator": "casing",
      "parameters": { "source": "name", "toLower": false },
      "replaces": "SPECA"
    },
    "appNameLower": {
      "type": "generated",
      "generator": "casing",
      "parameters": { "source": "AppName", "toLower": true },
      "replaces": "portal",
      "fileRename": "portal"
    },
    "skipRestore": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Lewati 'dotnet restore' otomatis setelah instantiate."
    },
    "dataComm": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        { "choice": "proto", "description": "Sertakan jalur gRPC/Proto (Libs/Contracts + server + demo /RpcDemo)." },
        { "choice": "none", "description": "Tanpa gRPC/Proto." }
      ],
      "defaultValue": "proto",
      "description": "Sertakan jalur komunikasi data gRPC/Proto (Libs/Contracts, server gRPC-Web, demo /RpcDemo)."
    },
    "proto": {
      "type": "computed",
      "value": "(dataComm == \"proto\")"
    },
    "theme": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        { "choice": "both", "description": "Kedua tema (theme1 Metronic + theme2 Vuexy) + preview banding." },
        { "choice": "theme1", "description": "Hanya theme1 (rasa Metronic)." },
        { "choice": "theme2", "description": "Hanya theme2 (rasa Vuexy)." }
      ],
      "defaultValue": "both",
      "description": "Tema yang disertakan. 'both' = showcase 2 tema; satu tema = file tema lain + dashboard-nya dibuang & style.css memakai tema terpilih."
    },
    "useTheme1": {
      "type": "computed",
      "value": "(theme == \"both\" || theme == \"theme1\")"
    },
    "useTheme2": {
      "type": "computed",
      "value": "(theme == \"both\" || theme == \"theme2\")"
    },
    "themeAggregate": {
      "type": "generated",
      "generator": "switch",
      "replaces": "_theme1",
      "parameters": {
        "evaluator": "C++",
        "datatype": "string",
        "cases": [
          { "condition": "(theme == \"theme2\")", "value": "_theme2" },
          { "condition": "", "value": "_theme1" }
        ]
      }
    },
    "dataAuth": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        { "choice": "none", "description": "Tanpa auth/DB." },
        { "choice": "identity", "description": "ASP.NET Identity + EF Core + Dapper (Libs/Data, SQLite, demo /Products)." }
      ],
      "defaultValue": "none",
      "description": "Sertakan auth + akses data: ASP.NET Identity (EF Core) + query Dapper di Libs/Data. Default none (instance ramping). (Simbol BUKAN bernama 'auth' agar tak dibajak UI 'Authentication type' bawaan VS.)"
    },
    "useAuth": {
      "type": "computed",
      "value": "(dataAuth == \"identity\")"
    },
    "content": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        { "choice": "demo", "description": "Demo/showcase lengkap: semua halaman contoh (Components, Charts, Tables, Calendar, Advanced, React, Repeater, Settings, Layout2) + Home preview tema." },
        { "choice": "starter", "description": "Starter ramping: hanya Home + Dashboard + Account + halaman Error/Privacy; halaman showcase & menu demo dibuang (komponen Libs/UI tetap tersedia)." }
      ],
      "defaultValue": "demo",
      "description": "Cakupan konten halaman. 'demo' = showcase lengkap (default). 'starter' = kanvas ramping siap dikembangkan."
    },
    "isStarter": {
      "type": "computed",
      "value": "(content == \"starter\")"
    },
    "desktop": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Sertakan Apps/Desktop: shell Tauri (Rust) yang membungkus frontend web — dev memuat server dev, produksi membundel server publish self-contained sebagai sidecar."
    },
    "mobile": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Sertakan Apps/Mobile: aplikasi Flutter (Android+iOS) dengan klien Dart gRPC dari proto yang sama (demo SayHello; butuh --data-comm proto untuk round-trip)."
    }
  },
  "SpecialCustomOperations": {
    "**/buf.gen.yaml": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": ["#if"],
            "else": ["#else"],
            "elseif": ["#elseif"],
            "endif": ["#endif"],
            "trim": true,
            "wholeLine": true
          }
        }
      ]
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "copyOnly": [
            "Apps/Mobile/android/settings.gradle.kts",
            "Apps/Mobile/ios/Runner.xcodeproj/project.pbxproj"
          ]
        },
        {
          "exclude": [
            "**/[Bb]in/**",
            "**/[Oo]bj/**",
            "**/node_modules/**",
            "**/wwwroot/dist/**",
            "**/.vs/**",
            "**/.git/**",
            "**/.github/workflows/**",
            "**/_pub/**",
            "**/publish/**",
            "**/certs/**",
            "**/*.user",
            "pnpm-lock.yaml",
            "BACKLOG.md",
            "TEMPLATE.md",
            "packaging/**",
            "_nupkg/**",
            ".template.config/**",
            "**/.dart_tool/**",
            "**/.idea/**",
            "**/*.iml",
            "Apps/Mobile/build/**",
            "Apps/Mobile/android/.gradle/**",
            "Apps/Mobile/android/local.properties",
            "Apps/Mobile/pubspec.lock",
            "**/ephemeral/**",
            "Apps/Mobile/ios/Flutter/flutter_export_environment.sh",
            "Apps/Mobile/ios/Flutter/Generated.xcconfig",
            "Apps/Desktop/src-tauri/target/**",
            "Apps/Desktop/src-tauri/resources/**",
            "Apps/Desktop/src-tauri/gen/**"
          ]
        },
        {
          "include": [
            "Apps/Desktop/src-tauri/resources/portal/.gitkeep"
          ]
        },
        {
          "condition": "(!desktop)",
          "exclude": [
            "Apps/Desktop/**",
            "scripts/desktop-publish-portal.mjs"
          ]
        },
        {
          "condition": "(!mobile)",
          "exclude": [
            "Apps/Mobile/**"
          ]
        },
        {
          "condition": "(!proto)",
          "exclude": [
            "Libs/Contracts/**",
            "Apps/Portal/Services/**",
            "Apps/Portal/Pages/RpcDemo.cshtml",
            "Apps/Portal/Assets/Entries/rpcdemo.tsx",
            "Apps/Portal/Assets/gen/**",
            "buf.yaml",
            "buf.gen.yaml",
            "scripts/rpc-smoke.ts"
          ]
        },
        {
          "condition": "(!useAuth)",
          "exclude": [
            "Libs/Data/**",
            "Apps/Portal/Pages/Products.cshtml",
            "Apps/Portal/Pages/Products.cshtml.cs",
            "Apps/Portal/Pages/Account/Logout.cshtml",
            "Apps/Portal/Pages/Account/Logout.cshtml.cs",
            "Apps/Portal/Endpoints/**",
            "scripts/auth-smoke.ts",
            ".config/dotnet-tools.json"
          ]
        },
        {
          "condition": "(isStarter)",
          "exclude": [
            "Apps/Portal/Pages/Advanced.cshtml",
            "Apps/Portal/Pages/Calendar.cshtml",
            "Apps/Portal/Pages/Charts.cshtml",
            "Apps/Portal/Pages/Charts.cshtml.cs",
            "Apps/Portal/Pages/Components.cshtml",
            "Apps/Portal/Pages/Components.cshtml.cs",
            "Apps/Portal/Pages/Tables.cshtml",
            "Apps/Portal/Pages/Tables.cshtml.cs",
            "Apps/Portal/Pages/RepeaterDemo.cshtml",
            "Apps/Portal/Pages/RepeaterDemo.cshtml.cs",
            "Apps/Portal/Pages/ReactDemo.cshtml",
            "Apps/Portal/Pages/ReactDemo.cshtml.cs",
            "Apps/Portal/Pages/Layout2.cshtml",
            "Apps/Portal/Pages/Layout2.cshtml.cs",
            "Apps/Portal/Pages/Settings.cshtml",
            "Apps/Portal/Pages/Settings.cshtml.cs",
            "Apps/Portal/Pages/Shared/_HomePreview.cshtml"
          ]
        },
        {
          "condition": "(!useTheme1)",
          "exclude": [
            "Libs/UI/Assets/Themes/theme1/**",
            "Libs/UI/Assets/Themes/_theme1.css",
            "Libs/UI/Assets/Themes/style01.css",
            "Apps/Portal/Pages/Dashboards/Metronic.cshtml",
            "Apps/Portal/Pages/Dashboards/Metronic.cshtml.cs"
          ]
        },
        {
          "condition": "(!useTheme2)",
          "exclude": [
            "Libs/UI/Assets/Themes/theme2/**",
            "Libs/UI/Assets/Themes/_theme2.css",
            "Libs/UI/Assets/Themes/style02.css",
            "Apps/Portal/Pages/Dashboards/Vuexy.cshtml",
            "Apps/Portal/Pages/Dashboards/Vuexy.cshtml.cs"
          ]
        }
      ]
    }
  ],
  "postActions": [
    {
      "condition": "(!skipRestore)",
      "description": "Restore .NET dependencies",
      "manualInstructions": [
        { "text": "Jalankan 'dotnet restore', lalu 'pnpm install' di root solution (build pertama juga menjalankan 'pnpm i' otomatis), lalu F5 / 'dotnet run'." }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
