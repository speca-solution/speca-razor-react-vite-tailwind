<!DOCTYPE html>
@*
    Layout BLANK — tanpa shell navigasi. Untuk auth, error, print (konten di tengah).
    Catatan: halaman landing/marketing biasanya butuh chrome sendiri → bukan Blank.
*@
@{
    // Halaman Blank (auth/error) tidak memakai ikon Lucide → jangan muat (lebih ringan).
    ViewData["LoadLucide"] = false;
}
<html class="h-full" lang="en" dir="ltr">
<head>
    @await Html.PartialAsync("_Head")
    @RenderSection("Styles", required: false)
</head>

<body class="bg-muted/40 text-foreground flex min-h-full flex-col items-center justify-center p-4 antialiased">

    <div class="fixed top-4 end-4 z-10">
        <button type="button" class="btn-icon" data-theme-toggle aria-label="Toggle dark mode">
            <i class="ti ti-moon text-lg dark:hidden"></i>
            <i class="ti ti-sun hidden text-lg dark:inline"></i>
        </button>
    </div>

    <div class="w-full max-w-[420px] py-6">
        @RenderBody()
    </div>

    <vite-asset src="Libs/UI/Assets/Entries/layouts/blank.js" />

    @RenderSection("Scripts", required: false)
</body>
</html>
