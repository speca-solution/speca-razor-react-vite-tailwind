<!DOCTYPE html>
@*
    Layout2 — struktur HORIZONTAL: topbar berisi brand + menu horizontal (desktop),
    drawer sidebar untuk mobile. Endpoint tema dimuat via style.css; halaman bisa
    pratinjau tema lain dengan ViewData["Style"]="style02".
    Adaptif: < lg menu pindah ke drawer (burger), >= lg menu di topbar.
*@
@{
    var style = ViewData["Style"] as string ?? "style";
    var stickyNavbar = ViewData["StickyNavbar"] as bool? ?? true;
    ViewData["SidebarDrawerOnly"] = true;
    // Nonce CSP (produksi): Razor MENGHILANGKAN atribut nonce bila null (dev) → aman.
    var cspNonce = Context.Items["csp-nonce"] as string;
}
<html class="h-full" lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Public+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <vite-asset src="Libs/UI/Assets/Vendors/tabler-icons/style.css" />
    <vite-asset src="Libs/UI/Assets/Vendors/lucide/style.css" />
    <vite-asset src="Libs/UI/Assets/Themes/@(style).css" />

    @RenderSection("Styles", false)

    <!-- Set dark-mode sebelum render untuk hindari flash -->
    <script nonce="@cspNonce">
        (function () {
            var mode = localStorage.getItem('speca-theme');
            if (!mode) {
                mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            if (mode === 'dark') { document.documentElement.classList.add('dark'); }
        })();
    </script>
</head>

<body class="bg-background text-foreground flex h-full flex-col text-base antialiased">

    <!-- Overlay drawer mobile -->
    <div class="fixed inset-0 z-40 hidden bg-black/40" data-sidebar-overlay></div>

    @* Drawer menu (mobile & tablet) — markup sama dengan sidebar vertikal *@
    @await Html.PartialAsync("_Sidebar")

    <!-- Topbar -->
    <header class="app-header border-border bg-background @(stickyNavbar ? "sticky top-0 z-30" : "") border-b">
        <div class="container-fixed flex h-[64px] items-center gap-4">
            <button type="button" class="btn-icon lg:hidden" data-sidebar-toggle aria-label="Buka menu">
                <i class="ti ti-menu-2 text-lg"></i>
            </button>

            <a href="/" class="text-mono text-lg font-semibold tracking-tight">Speca</a>

            @await Html.PartialAsync("_Menu_Horizontal")

            <div class="ms-auto">
                @await Html.PartialAsync("_Header_Actions")
            </div>
        </div>
    </header>

    <main class="grow pt-5" role="content">
        <div class="container-fixed">
            @RenderSection("Breadcrumb", false)
        </div>
        <div class="container-fixed">
            @RenderBody()
        </div>
    </main>

    @await Html.PartialAsync("_Footer")

    @RenderSection("EndOfPage", false)

    <vite-asset src="Libs/UI/Assets/Entries/layouts/horizontal.js" />

    @RenderSection("Scripts", false)
</body>
</html>
