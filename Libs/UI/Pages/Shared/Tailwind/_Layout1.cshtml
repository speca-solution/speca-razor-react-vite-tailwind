<!DOCTYPE html>
@*
    Layout Tailwind 4 murni — app shell ala Metronic (sidebar fixed + header + footer).
    Markup & style milik sendiri; Metronic hanya referensi desain. Tanpa KTUI.

*@
@{
    var theme = ViewData["Theme"] as string ?? "theme1";
    // Nonce CSP (produksi): Razor MENGHILANGKAN atribut nonce bila null (dev) → aman.
    var cspNonce = Context.Items["csp-nonce"] as string;
}
<html class="h-full @theme" lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Public+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <vite-asset src="Libs/UI/Assets/Vendors/tabler-icons/style.css" />
    <vite-asset src="Libs/UI/Assets/Vendors/lucide/style.css" />
    <vite-asset src="Libs/UI/Assets/Themes/tailwind/theme.css" />

    @RenderSection("Styles", false)

    <!-- Set dark-mode & skin sebelum render untuk hindari flash -->
    <script nonce="@cspNonce">
        (function () {
            var el = document.documentElement;
            var mode = localStorage.getItem('speca-theme');
            if (!mode) {
                mode = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            if (mode === 'dark') { el.classList.add('dark'); }
            // Skin theme1/theme2: localStorage menang atas default SSR (class @@theme).
            var skin = localStorage.getItem('speca-skin');
            if (skin === 'theme2') { el.classList.add('theme2'); }
            else if (skin === 'theme1') { el.classList.remove('theme2'); }
        })();
    </script>
</head>

<body class="bg-background text-foreground flex h-full text-base antialiased">

    <!-- Overlay drawer mobile -->
    <div class="fixed inset-0 z-40 hidden bg-black/40 lg:hidden" data-sidebar-overlay></div>

    @await Html.PartialAsync("Tailwind/_Sidebar")

    <!-- Wrapper -->
    <div class="app-wrapper flex min-h-screen grow flex-col lg:ms-[270px]">

        @await Html.PartialAsync("Tailwind/_Header")

        <main class="grow pt-5" role="content">
            <div class="container-fixed">
                @RenderSection("Breadcrumb", false)
            </div>
            <div class="container-fixed">
                @RenderBody()
            </div>
        </main>

        @await Html.PartialAsync("Tailwind/_Footer")
    </div>

    @RenderSection("EndOfPage", false)

    <vite-asset src="Libs/UI/Assets/Themes/tailwind/app/layouts/vertical.js" />

    @RenderSection("Scripts", false)
</body>
</html>
