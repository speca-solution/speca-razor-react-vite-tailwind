@model Speca.UI.Components.PaginationViewModel
@{
    // Jendela halaman: 1 … (p-1) p (p+1) … N — token "…" tidak bisa diklik.
    var tokens = new List<int?>();
    if (Model.TotalPages > 1)
    {
        var around = new SortedSet<int> { 1, Model.TotalPages };
        for (var i = Model.Page - 1; i <= Model.Page + 1; i++)
        {
            if (i >= 1 && i <= Model.TotalPages) { around.Add(i); }
        }
        int? prev = null;
        foreach (var p in around)
        {
            if (prev is int q && p - q > 1) { tokens.Add(null); }
            tokens.Add(p);
            prev = p;
        }
    }
}
@if (Model.TotalPages > 1)
{
    <nav class="pagination" aria-label="Pagination">
        @if (Model.Page > 1)
        {
            <a class="page-link" href="@Model.UrlFor(Model.Page - 1)" aria-label="Sebelumnya"><i class="ti ti-chevron-left"></i></a>
        }
        else
        {
            <span class="page-link pointer-events-none opacity-50"><i class="ti ti-chevron-left"></i></span>
        }

        @foreach (var token in tokens)
        {
            @if (token is int p)
            {
                <a class="page-link @(p == Model.Page ? "active" : "")" href="@Model.UrlFor(p)">@p</a>
            }
            else
            {
                <span class="page-link pointer-events-none">…</span>
            }
        }

        @if (Model.Page < Model.TotalPages)
        {
            <a class="page-link" href="@Model.UrlFor(Model.Page + 1)" aria-label="Berikutnya"><i class="ti ti-chevron-right"></i></a>
        }
        else
        {
            <span class="page-link pointer-events-none opacity-50"><i class="ti ti-chevron-right"></i></span>
        }
    </nav>
}
