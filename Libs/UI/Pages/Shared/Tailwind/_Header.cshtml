@* Header ala Metronic: burger (mobile), collapse sidebar (desktop), search,
   dark mode, notifikasi (dropdown), user menu (dropdown).
   Sticky default; matikan per halaman: ViewData["StickyNavbar"] = false *@
@{
    var stickyNavbar = ViewData["StickyNavbar"] as bool? ?? true;
}
<header class="app-header border-border bg-background @(stickyNavbar ? "sticky top-0 z-30" : "") flex h-[58px] shrink-0 items-center justify-between gap-3 border-b px-5">
    <div class="flex grow items-center gap-1.5">
        <button type="button" class="btn-icon lg:hidden" data-sidebar-toggle aria-label="Buka menu">
            <i class="ti ti-menu-2 text-lg"></i>
        </button>
        <button type="button" class="btn-icon hidden lg:inline-flex" data-sidebar-collapse aria-label="Sembunyikan sidebar">
            <i class="ti ti-layout-sidebar-left-collapse text-lg"></i>
        </button>

        <label class="border-input hidden h-9 w-full max-w-[280px] items-center gap-2 rounded-md border px-3 md:flex">
            <i class="ti ti-search text-muted-foreground"></i>
            <input type="text"
                   class="placeholder:text-muted-foreground w-full bg-transparent text-sm outline-none"
                   placeholder="Cari... (Ctrl+/)" data-search-input />
        </label>
    </div>

    <div class="flex items-center gap-1.5">
        <button type="button" class="btn-icon" data-theme-toggle aria-label="Toggle dark mode">
            <i class="ti ti-moon text-lg dark:hidden"></i>
            <i class="ti ti-sun hidden text-lg dark:inline"></i>
        </button>

        <!-- Notifikasi -->
        <div class="relative">
            <button type="button" class="btn-icon relative" data-dropdown-toggle="#header_notifications" aria-label="Notifikasi">
                <i class="ti ti-bell text-lg"></i>
                <span class="bg-primary absolute end-2 top-2 size-1.5 rounded-full"></span>
            </button>
            <div id="header_notifications" class="dropdown-panel hidden">
                <div class="text-mono px-2.5 pt-1.5 pb-2 text-sm font-semibold">Notifikasi</div>
                <a class="dropdown-item" href="#">
                    <span class="bg-primary mt-0.5 size-2 shrink-0 rounded-full"></span>
                    <span>
                        Order <span class="text-mono font-medium">#10231</span> dibayar
                        <span class="text-muted-foreground block text-xs">5 menit lalu</span>
                    </span>
                </a>
                <a class="dropdown-item" href="#">
                    <span class="mt-0.5 size-2 shrink-0 rounded-full bg-green-500"></span>
                    <span>
                        User baru mendaftar
                        <span class="text-muted-foreground block text-xs">32 menit lalu</span>
                    </span>
                </a>
                <a class="dropdown-item" href="#">
                    <span class="mt-0.5 size-2 shrink-0 rounded-full bg-amber-500"></span>
                    <span>
                        Stok SKU-88 hampir habis
                        <span class="text-muted-foreground block text-xs">1 jam lalu</span>
                    </span>
                </a>
                <div class="border-border mt-1.5 border-t pt-1.5">
                    <a class="dropdown-item text-primary justify-center font-medium" href="#">Lihat semua</a>
                </div>
            </div>
        </div>

        <!-- User menu -->
        <div class="relative">
            <button type="button"
                    class="bg-primary text-primary-foreground flex size-8 items-center justify-center rounded-full text-xs font-semibold"
                    data-dropdown-toggle="#header_user" aria-label="User menu">
                S
            </button>
            <div id="header_user" class="dropdown-panel hidden w-56">
                <div class="border-border border-b px-2.5 pt-1.5 pb-2.5">
                    <div class="text-mono text-sm font-semibold">Speca Admin</div>
                    <div class="text-muted-foreground text-xs">admin@speca.local</div>
                </div>
                <div class="pt-1.5">
                    <a class="dropdown-item" href="#"><i class="ti ti-user"></i>Profil</a>
                    <a class="dropdown-item" href="#"><i class="ti ti-settings"></i>Pengaturan</a>
                    <a class="dropdown-item" href="/Privacy"><i class="ti ti-shield-lock"></i>Privacy</a>
                </div>
                <div class="border-border mt-1.5 border-t pt-1.5">
                    <a class="dropdown-item text-red-600 dark:text-red-400" href="#"><i class="ti ti-logout"></i>Keluar</a>
                </div>
            </div>
        </div>
    </div>
</header>
