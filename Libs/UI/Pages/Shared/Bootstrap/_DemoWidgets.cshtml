@* Widget contoh (KPI, tabel, aktivitas, progress) — Bootstrap 5 murni, gaya referensi Vuexy/Metronic.
   Dipakai Layout2 dan Layout4; tampilan menyesuaikan skin SCSS masing-masing. *@

<div class="row g-4">
    <!-- KPI -->
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <i class="bi bi-currency-dollar text-primary fs-3"></i>
                <h4 class="mb-0 mt-2">Rp 52,4 jt</h4>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-body-secondary">Pendapatan bulan ini</small>
                    <span class="badge text-bg-success">+12%</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <i class="bi bi-cart3 text-primary fs-3"></i>
                <h4 class="mb-0 mt-2">1.235</h4>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-body-secondary">Order</small>
                    <span class="badge text-bg-danger">-3%</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <i class="bi bi-people text-primary fs-3"></i>
                <h4 class="mb-0 mt-2">89</h4>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-body-secondary">User baru</small>
                    <span class="badge text-bg-success">+8%</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <i class="bi bi-percent text-primary fs-3"></i>
                <h4 class="mb-0 mt-2">4,6%</h4>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-body-secondary">Konversi</small>
                    <span class="badge text-bg-warning">0%</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabel -->
    <div class="col-xl-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Order Terbaru</h5>
                <a href="#" class="small">Lihat semua</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="text-uppercase small text-body-secondary">
                        <tr>
                            <th>Order</th>
                            <th>Pelanggan</th>
                            <th>Status</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-medium">#10231</td>
                            <td>Budi Santoso</td>
                            <td><span class="badge text-bg-success">Lunas</span></td>
                            <td class="text-end">Rp 1.250.000</td>
                        </tr>
                        <tr>
                            <td class="fw-medium">#10230</td>
                            <td>Siti Aminah</td>
                            <td><span class="badge text-bg-warning">Menunggu</span></td>
                            <td class="text-end">Rp 480.000</td>
                        </tr>
                        <tr>
                            <td class="fw-medium">#10229</td>
                            <td>Andi Wijaya</td>
                            <td><span class="badge text-bg-danger">Batal</span></td>
                            <td class="text-end">Rp 2.100.000</td>
                        </tr>
                        <tr>
                            <td class="fw-medium">#10228</td>
                            <td>Dewi Lestari</td>
                            <td><span class="badge text-bg-primary">Dikirim</span></td>
                            <td class="text-end">Rp 760.000</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Aktivitas + progress -->
    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="card-title mb-0">Aktivitas</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled d-flex flex-column gap-3 mb-4">
                    <li class="d-flex gap-2">
                        <i class="bi bi-circle-fill text-primary" style="font-size: .5rem; margin-top: .4rem;"></i>
                        <div>
                            <div class="small">Order <span class="fw-medium">#10231</span> dibayar</div>
                            <div class="text-body-secondary small">5 menit lalu</div>
                        </div>
                    </li>
                    <li class="d-flex gap-2">
                        <i class="bi bi-circle-fill text-success" style="font-size: .5rem; margin-top: .4rem;"></i>
                        <div>
                            <div class="small">User baru <span class="fw-medium">rina@contoh.id</span> mendaftar</div>
                            <div class="text-body-secondary small">32 menit lalu</div>
                        </div>
                    </li>
                    <li class="d-flex gap-2">
                        <i class="bi bi-circle-fill text-warning" style="font-size: .5rem; margin-top: .4rem;"></i>
                        <div>
                            <div class="small">Stok <span class="fw-medium">SKU-88</span> hampir habis</div>
                            <div class="text-body-secondary small">1 jam lalu</div>
                        </div>
                    </li>
                    <li class="d-flex gap-2">
                        <i class="bi bi-circle-fill text-danger" style="font-size: .5rem; margin-top: .4rem;"></i>
                        <div>
                            <div class="small">Pembayaran <span class="fw-medium">#10229</span> gagal</div>
                            <div class="text-body-secondary small">2 jam lalu</div>
                        </div>
                    </li>
                </ul>

                <div class="d-flex justify-content-between small mb-1">
                    <span class="text-body-secondary">Target bulan ini</span>
                    <span class="fw-medium">68%</span>
                </div>
                <div class="progress" role="progressbar" aria-valuenow="68" aria-valuemin="0" aria-valuemax="100" style="height: .5rem;">
                    <div class="progress-bar" style="width: 68%"></div>
                </div>
            </div>
        </div>
    </div>
</div>
