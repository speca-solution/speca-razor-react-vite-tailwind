@* Navbar ala Vuexy: burger (mobile), collapse sidebar (desktop), search,
   notifikasi & user menu (dropdown Bootstrap native).
   Sticky default; matikan per halaman: ViewData["StickyNavbar"] = false *@
@{
    var stickyNavbar = ViewData["StickyNavbar"] as bool? ?? true;
}
<nav class="speca-navbar navbar navbar-expand gap-2 px-4 @(stickyNavbar ? "sticky-top" : "")">
    <button class="btn btn-outline-secondary d-lg-none" type="button"
            data-bs-toggle="offcanvas" data-bs-target="#specaSidebar" aria-controls="specaSidebar">
        <i class="bi bi-list"></i>
    </button>
    <button class="btn btn-light d-none d-lg-inline-flex" type="button"
            data-sidebar-collapse aria-label="Sembunyikan sidebar">
        <i class="bi bi-layout-sidebar"></i>
    </button>

    <div class="d-none d-md-flex align-items-center flex-grow-1" style="max-width: 320px;">
        <i class="bi bi-search text-body-secondary me-2"></i>
        <input type="text" class="form-control form-control-sm border-0 shadow-none bg-transparent px-0"
               placeholder="Cari... (Ctrl+/)" data-search-input />
    </div>

    <ul class="navbar-nav flex-row align-items-center ms-auto gap-1">
        <!-- Dark mode -->
        <li class="nav-item">
            <a class="nav-link px-2" href="#" data-theme-toggle aria-label="Toggle dark mode">
                <i class="bi bi-moon fs-5 icon-when-light"></i>
                <i class="bi bi-sun fs-5 icon-when-dark"></i>
            </a>
        </li>

        <!-- Notifikasi -->
        <li class="nav-item dropdown">
            <a class="nav-link position-relative px-2" href="#" role="button"
               data-bs-toggle="dropdown" aria-expanded="false" aria-label="Notifikasi">
                <i class="bi bi-bell fs-5"></i>
                <span class="position-absolute top-1 end-1 bg-primary rounded-circle" style="width:.5rem;height:.5rem;"></span>
            </a>
            <div class="dropdown-menu dropdown-menu-end p-0" style="min-width: 300px;">
                <div class="dropdown-header fw-semibold">Notifikasi</div>
                <a class="dropdown-item d-flex gap-2 py-2" href="#">
                    <i class="bi bi-circle-fill text-primary" style="font-size:.45rem;margin-top:.45rem;"></i>
                    <span class="small">
                        Order <span class="fw-medium">#10231</span> dibayar
                        <span class="d-block text-body-secondary">5 menit lalu</span>
                    </span>
                </a>
                <a class="dropdown-item d-flex gap-2 py-2" href="#">
                    <i class="bi bi-circle-fill text-success" style="font-size:.45rem;margin-top:.45rem;"></i>
                    <span class="small">
                        User baru mendaftar
                        <span class="d-block text-body-secondary">32 menit lalu</span>
                    </span>
                </a>
                <a class="dropdown-item d-flex gap-2 py-2" href="#">
                    <i class="bi bi-circle-fill text-warning" style="font-size:.45rem;margin-top:.45rem;"></i>
                    <span class="small">
                        Stok SKU-88 hampir habis
                        <span class="d-block text-body-secondary">1 jam lalu</span>
                    </span>
                </a>
                <div class="dropdown-divider my-0"></div>
                <a class="dropdown-item text-center text-primary small py-2" href="#">Lihat semua</a>
            </div>
        </li>

        <!-- User menu -->
        <li class="nav-item dropdown">
            <a class="nav-link px-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="User menu">
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white fw-semibold"
                      style="width:2rem;height:2rem;">S</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
                <li class="px-3 py-2">
                    <div class="fw-semibold">Speca Admin</div>
                    <div class="text-body-secondary small">admin@speca.local</div>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Profil</a></li>
                <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Pengaturan</a></li>
                <li><a class="dropdown-item" href="/Privacy"><i class="bi bi-shield-lock me-2"></i>Privacy</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Keluar</a></li>
            </ul>
        </li>
    </ul>
</nav>
