<!DOCTYPE html>
@*
    Layout4 — Bootstrap 5 murni, design language ala Metronic. Sidebar fixed (desktop) / offcanvas (mobile).
    Markup milik sendiri; Vuexy hanya referensi pola, bukan sumber kode.
    ISOLASI THEME: hanya memuat asset Bootstrap, jangan campur dengan Tailwind.
*@
<html lang="en" data-bs-theme="light">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <vite-asset src="Libs/UI/Assets/Vendors/bootstrap-icons/style.css" />
    <vite-asset src="Libs/UI/Assets/Themes/bootstrap/layout4.scss" />

    @RenderSection("Styles", false)

    <!-- Set theme sebelum render untuk hindari flash -->
    <script>
        (function () {
            var mode = localStorage.getItem('speca-theme');
            if (mode) { document.documentElement.setAttribute('data-bs-theme', mode); }
        })();
    </script>
</head>

<body class="bg-body-tertiary">
    <div class="speca-layout">

        @await Html.PartialAsync("Bootstrap/_Menu")

        <div class="speca-main d-flex flex-column min-vh-100">

            @await Html.PartialAsync("Bootstrap/_Navbar")

            <main class="container-fluid flex-grow-1 px-4 py-4">
                @RenderBody()
            </main>

            @await Html.PartialAsync("Bootstrap/_Footer")
        </div>
    </div>

    <vite-asset src="Libs/UI/Assets/Vendors/bootstrap/index.js" />
    <vite-asset src="Libs/UI/Assets/Themes/bootstrap/app/layouts/layout.js" />

    @RenderSection("Scripts", false)
</body>
</html>
