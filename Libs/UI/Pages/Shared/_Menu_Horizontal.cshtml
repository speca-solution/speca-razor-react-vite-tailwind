@using Speca.UI.Navigation
@inject Microsoft.Extensions.Options.IOptions<SpecaMenuOptions> MenuOptions
@{
    var menuItems = MenuOptions.Value.Items;
    var currentPath = (ViewContext.HttpContext.Request.Path.Value ?? "/").TrimEnd('/');
    if (currentPath.Length == 0) { currentPath = "/"; }

    var dropdownIndex = 0;
    const string DisabledClasses = "pointer-events-none opacity-50";

    void RenderBadge(MenuItem item)
    {
        if (item.Badge is null) { return; }
        <span class="badge badge-@item.BadgeVariant ms-auto">@item.Badge</span>
    }

    void RenderDropdownLink(MenuItem child, bool indent)
    {
        if (child.Disabled)
        {
            <span class="dropdown-item @DisabledClasses @(indent ? "ps-5" : "")">@child.Title @{ RenderBadge(child); }</span>
            return;
        }
        <a class="dropdown-item @(indent ? "ps-5" : "") @(child.IsActive(currentPath) ? "text-primary font-semibold" : "")"
           href="@(child.Url ?? "#")"
           target="@(child.OpenInNewTab ? "_blank" : null)"
           rel="@(child.OpenInNewTab ? "noopener" : null)">
            @child.Title
            @if (child.OpenInNewTab)
            {
                <i class="ti ti-external-link text-muted-foreground text-xs"></i>
            }
            @{ RenderBadge(child); }
        </a>
    }
}

@* Menu horizontal (desktop) untuk layout horizontal — heading dilewati.
   Top item pakai komponen .menu-link (state aktif per-tema). Kedalaman dibatasi:
   level-3 = GRUP berlabel di dalam dropdown (bukan flyout bersarang). *@
<nav class="hidden items-center gap-0.5 lg:flex" id="horizontal_menu">
    @foreach (var item in menuItems)
    {
        @if (item.IsHeading)
        {
            continue;
        }
        else if (item.Disabled)
        {
            <span class="menu-link @DisabledClasses">
                <i class="menu-icon @(item.Icon ?? "ti ti-category")"></i>
                <span class="menu-label">@item.Title</span>
            </span>
        }
        else if (item.Children.Count == 0)
        {
            <a href="@(item.Url ?? "#")"
               target="@(item.OpenInNewTab ? "_blank" : null)"
               rel="@(item.OpenInNewTab ? "noopener" : null)"
               class="menu-link @(item.IsActive(currentPath) ? "menu-link-active" : "")">
                <i class="menu-icon @(item.Icon ?? "ti ti-category")"></i>
                <span class="menu-label">@item.Title</span>
            </a>
        }
        else
        {
            var dropdownId = $"hmenu{dropdownIndex++}";
            <div class="relative">
                @* Parent dgn anak aktif: hint teks primary (bukan pill penuh) *@
                <button type="button"
                        class="menu-link @(item.HasActiveDescendant(currentPath) ? "text-primary" : "")"
                        data-dropdown-toggle="#@dropdownId">
                    <i class="menu-icon @(item.Icon ?? "ti ti-category")"></i>
                    <span class="menu-label">@item.Title</span>
                    <i class="menu-chevron ti ti-chevron-down"></i>
                </button>
                <div id="@dropdownId" class="dropdown-panel start-0! end-auto! hidden w-60">
                    @foreach (var child in item.Children)
                    {
                        @if (child.Children.Count == 0)
                        {
                            RenderDropdownLink(child, indent: false);
                        }
                        else
                        {
                            <div class="text-muted-foreground px-2.5 pt-2 pb-1 text-xs font-medium uppercase">
                                @child.Title
                            </div>
                            foreach (var grandChild in child.Children)
                            {
                                RenderDropdownLink(grandChild, indent: true);
                            }
                        }
                    }
                </div>
            </div>
        }
    }
</nav>
