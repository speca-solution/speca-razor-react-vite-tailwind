{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler", // Ini kunci untuk Vite 6 + .NET 10
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true, // Diperlukan untuk vite.config.ts jika mengimpor file .ts lain
    "noEmit": true, // Vite yang akan menangani kompilasi, bukan tsc
    "paths": {
      "@app/*": [ "./Apps/Portal/Assets/*" ],
      "@ui/*": [ "./Libs/UI/Assets/*" ]
    }
  },
  "include": [
    "vite.config.ts",
    "Libs/UI/Assets/**/*.ts",
    "Libs/UI/Assets/**/*.tsx",
    "Apps/*/Assets/**/*.ts",
    "Apps/*/Assets/**/*.tsx"
  ],
  // Themes & Vendors = kode vendored (KeenThemes/KTUI dkk), tidak ditulis dengan strict mode.
  // Tetap dikompilasi Vite, hanya dikecualikan dari type check.
  "exclude": [
    "node_modules",
    "Libs/UI/Assets/Themes",
    "Libs/UI/Assets/Vendors"
  ]
}