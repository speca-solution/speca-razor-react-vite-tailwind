{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler", // Ini kunci untuk Vite 6 + .NET 10
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true, // Diperlukan untuk vite.config.ts jika mengimpor file .ts lain
    "noEmit": true, // Vite yang akan menangani kompilasi, bukan tsc
    "baseUrl": ".",
    "paths": {
      "@app/*": [ "Apps/Portal/Assets/*" ],
      "@ui/*": [ "Libs/UI/Assets/*" ]
    }
  },
  "include": [
    "vite.config.ts",
    "Libs/UI/Assets/**/*.ts",
    "Libs/UI/Assets/**/*.tsx",
    "Apps/Portal/Assets/**/*.ts",
    "Apps/Portal/Assets/**/*.tsx"
  ],
  "node_modules": [ "node_modules" ]
}